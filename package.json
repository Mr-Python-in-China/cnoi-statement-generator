    "format": "oxfmt",
    "preview": "react-router preview",
    "router-typegen": "react-router typegen",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "update-example-template": "vite-node scripts/update-example-template.ts",
    "compile-examples": "vite-node scripts/compile-examples.ts",
    "quality": "oxfmt --check && npm run lint && tsc -b && npm run test",
    "prepare": "husky && npm run update-example-template && npm run compile-examples && npm run router-typegen"
  },
